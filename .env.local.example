# LOCAL (tu máquina)
# Copia a: .env.local (NO lo subas a git)

DJANGO_SECRET_KEY=dev-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# IMPORTANTE: deja DATABASE_URL vacío para usar Postgres local por variables DB_*
DATABASE_URL=

DB_NAME=acosignature
DB_USER=acosignature_user
DB_PASSWORD=cambia-esto
DB_HOST=127.0.0.1
DB_PORT=5432
DB_SSLMODE=disable

CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

JWT_SIGNING_KEY=dev-jwt-signing-key-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=1

THROTTLE_ANON=60/hour
THROTTLE_USER=600/hour
THROTTLE_AUTH=20/minute
THROTTLE_DOCUMENTS=120/minute

SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
LOG_LEVEL=INFO

# Email (opcional en local)
# OJO: debe iniciar por "django.core.mail.backends..."
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@acosignature.local

# Media en S3 (opcional para pruebas locales con bucket real)
USE_S3_MEDIA=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=
AWS_QUERYSTRING_AUTH=False
