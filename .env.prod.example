# PRODUCCIÓN (Neon + Render / similar)
# Copia a: .env.prod (NO lo subas a git)

DJANGO_SECRET_KEY=prod-change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=acosignature.onrender.com

# Neon: pega el connection string completo
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require
DB_CONN_MAX_AGE=0

# Si usas DATABASE_URL, estas DB_* normalmente NO hacen falta (pero no molestan si quedan vacías)
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
DB_SSLMODE=require

CORS_ALLOWED_ORIGINS=https://tu-sitio-wordpress.com,https://www.tu-sitio-wordpress.com

JWT_SIGNING_KEY=prod-jwt-signing-key-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=1

THROTTLE_ANON=60/hour
THROTTLE_USER=600/hour
THROTTLE_AUTH=20/minute
THROTTLE_DOCUMENTS=120/minute

SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
LOG_LEVEL=INFO
