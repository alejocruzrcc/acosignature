DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Neon / Render (recomendado): pega el connection string completo
# Ejemplo (NO commitees passwords reales):
# DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-xxxx-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Local Postgres (alternativa): usa estas variables si NO usas DATABASE_URL
DB_NAME=acosignature
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=disable
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

JWT_SIGNING_KEY=change-me-too
JWT_ALGORITHM=HS256
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=1

THROTTLE_ANON=60/hour
THROTTLE_USER=600/hour
THROTTLE_AUTH=20/minute
THROTTLE_DOCUMENTS=120/minute

SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
LOG_LEVEL=INFO
